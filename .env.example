# ─────────────────────────────────────────────────────────────────────────────
# ShopMind AI — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_DEBUG=true
APP_NAME="ShopMind AI"

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://shopmind:shopmind_pass@localhost:5432/shopmind_db

# Used by Alembic (sync driver) for migrations only
SYNC_DATABASE_URL=postgresql+psycopg2://shopmind:shopmind_pass@localhost:5432/shopmind_db

# ── LLM: Groq ────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Search: SerpAPI ──────────────────────────────────────────────────────────
# Get your key at: https://serpapi.com
SERP_API_KEY=your_serpapi_key_here

# ── Notifications: Twilio WhatsApp ───────────────────────────────────────────
# Get credentials at: https://console.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number

# ── Product Cache ─────────────────────────────────────────────────────────────
# How many hours before a cached product search expires
PRODUCT_CACHE_TTL_HOURS=6

# ── Alert Scheduler ──────────────────────────────────────────────────────────
# Cron expression for the daily price-check job (default: 8 AM every day)
ALERT_SCHEDULE_HOUR=8
ALERT_SCHEDULE_MINUTE=0
