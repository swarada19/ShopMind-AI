FROM python:3.12-slim

WORKDIR /app

RUN pip install --no-cache-dir streamlit==1.40.0 httpx==0.27.2

COPY frontend/ ./frontend/

RUN useradd -m -u 1000 shopmind && chown -R shopmind:shopmind /app
USER shopmind

EXPOSE 8501

CMD ["streamlit", "run", "frontend/app.py", "--server.port=8501", "--server.address=0.0.0.0"]
